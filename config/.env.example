# ─────────────────────────────────────────────────────
# Kickchain Bot — Environment Variables
# ─────────────────────────────────────────────────────
# Copy this file to config/.env and fill in your values.

# 1. Get from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# 2. Your personal Telegram user ID (the admin)
#    Get it by messaging @userinfobot
ADMIN_CHAT_ID=123456789

# 2b. (Optional) second admin user ID (also receives collected opinions)
SECOND_ADMIN_CHAT_ID=

# 2c. (Optional) comma-separated admin IDs (alternative to fields above)
# ADMIN_CHAT_IDS=123456789,987654321

# 3. Your Kickchain group chat ID
#    Forward a message from the group to @userinfobot  
#    It looks like: -1001234567890
GROUP_ID=-1001234567890

# 4. (Optional) announcement channel targets (comma-separated)
#    Use channel IDs and/or @channelusername values
# ANNOUNCEMENT_CHANNEL_IDS=-1001234567890,@kickchainchannel
ANNOUNCEMENT_CHANNEL_IDS=

# 5. (Optional) OpenAI API key for smarter /ask answers
#    Leave blank to use the built-in keyword-based fallback
OPENAI_API_KEY=
